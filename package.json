{
  "name": "repack",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "prepare": "is-in-ci || husky",
    "build": "turbo run build",
    "dev": "turbo watch build",
    "lint": "biome check --write",
    "lint:ci": "biome check",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "release": "pnpm build && pnpm lint && pnpm test && pnpm changeset publish",
    "pods": "turbo run pods",
    "pods:update": "turbo run pods:update",
    "website:start": "pnpm --filter website run start",
    "website:build": "pnpm --filter website run export"
  },
  "devDependencies": {
    "@babel/cli": "^7.25.2",
    "@babel/core": "^7.25.2",
    "@babel/plugin-syntax-flow": "^7.23.3",
    "@babel/plugin-transform-react-jsx": "^7.23.4",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-typescript": "^7.23.3",
    "@babel/runtime": "^7.25.0",
    "@biomejs/biome": "^1.9.4",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "husky": "^9.1.6",
    "is-in-ci": "^1.0.0",
    "turbo": "^2.8.16",
    "typescript": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "caniuse-lite": "^1.0.30001774"
    }
  }
}
